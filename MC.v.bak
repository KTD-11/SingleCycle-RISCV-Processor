module MC (
	input clk,
	input rst
);

//Program Counter
wire [31: 0] PC;
wire [31: 0] PCNext;

//ALU
wire [31: 0] SrcA;
wire [31: 0] SrcB;
wire [31: 0] ALUResult;
wire [2 : 0] ALUControl;
wire         zero;
wire         sign;

//Data Memory
wire [31: 0] ReadData;
wire [31: 0] WriteData;
wire         MemWrite;

//Control Unit
wire [1: 0]  ImmSrc;
wire         ResultSrc;
wire         RegWrite;
wire 	     ALUSrc;
wire         PCLoad;
wire         PCSrc;

//Register File
wire [31: 0] Result_WD3;

//Instruction Memory
wire [31: 0] Instr;

//Sign Extender
wire [31: 0] ImmExt;


ALU ALU_instance (
	.SrcA(SrcA), 
	.SrcB(SrcB), 
	.ALUControl(ALUControl), 
	.zero(zero), 
	.sign(sign),
	.ALUResult(ALUResult)
);

Data_Memory Data_Memory_instance(
	.A(ALUResult),
  	.WD(WriteData),
  	.WE(MemWrite),
  	.clk(clk),
	.RD(ReadData)
);

MUX2x1 MUX_R_DataMemory(
	.A(aALUResult),
	.B(ReadDat),
	.S(ResultSrc),
	.Z(Result_WD3)
);

Register_File Register_File_instance(
  	.A1(Instr[19: 15]),
  	.A2(Instr[24: 20]),
  	.A3(Instr[11:  7]),
  	.WD3(Result_WD3),
  	.WE(RegWrite),
  	.clk(clk),
  	.rst(rst),
	.RD1(SrcA),
  	.RD2(WriteData)
);

MUX2x1 MUX_R_Register_File(
	.A(WriteData),
	.B(ImmExt),
	.S(ALUSrc),
	.Z(SrcB)
);

Instruction_Memory Instruction_Memory_instance(
  	.PC(PC),
  	.Instr(Instr)
);

Program_Counter Program_Counter_instance(
  	.clk(clk),
  	.rst(rst), 
  	.load(PCLoad),
  	.PCNext(PCNext),
	.PC(PC)
);

PC_Calculation PC_Calculation_instance(
  	.PCSrc(PCSrc),
  	.PC(PC),
  	.ImmExt(ImmExt),
	.PCNext(PCNext)
);


Sign_Extend Sign_Extend_instance(
 	.Instr(Instr[31: 7]),	
	.ImmSrc(ImmSrc),
	.ImmExt(ImmExt)
);

Control_Unit Control_Unit_instance(
	.Instr(Instr),
  	.zero(zero),
	.sign(sign),
	.PCSrc(PCSrc),
	.ResultSrc(ResultSrc),
	.MemWrite(MemWrite),
  	.ALUSrc(ALUSrc),
  	.RegWrite(RegWrite),
  	.PCLoad(PCLoad),
  	.ImmSrc(ImmSrc),
  	.ALUControl(ALUControl)
);

endmodule