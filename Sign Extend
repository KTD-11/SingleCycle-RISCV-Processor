module Sign_Extend(
  input      [31: 7] Instr,
  input      [1 : 0] ImmSrc,

  output reg [31: 0] ImmExt
);

always @(*) begin
  case (ImmSrc) 
    'b00: ImmExt = {20{Instr[31]}, {Instr[31: 20]}};
    'b01: ImmExt = {20{Instr[31]}, Instr[31:  25], Instr[11: 7]};
    'b10: ImmExt = {20{Instr[31]}, Instr[7], Instr[30: 25], Instr[11: 8], 'b0};
    default: ImmExt = 'b0;
  endcase 
end

endmodule
